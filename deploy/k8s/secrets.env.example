# Copy to deploy/k8s/secrets.env and fill with real values.
# This file is consumed by ansible/bootstrap-cluster.sh

# GHCR pull credentials (required)
GHCR_USERNAME=your-github-username
GHCR_PASSWORD=your-ghcr-pat-with-read-packages

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-postgres
POSTGRES_DB=userdb

# RabbitMQ
RABBITMQ_DEFAULT_USER=myapp
RABBITMQ_DEFAULT_PASS=change-me-rabbitmq
RABBITMQ_DEFAULT_VHOST=/
RABBITMQ_USERNAME=myapp
RABBITMQ_PASSWORD=change-me-rabbitmq
RABBITMQ_VHOST=/
# Optional override
# RABBITMQ_ADDRESSES=amqp://myapp:change-me-rabbitmq@rabbitmq:5672/

# Shared auth / app secrets
JWT_SECRET=change-me-jwt-secret
LLM_API_KEY=sk-or-xxxx
# Needs **repo** scope (clone private portable-platform-infra). Same value is used for Argo CD repo-server.
GITHUB_TOKEN=ghp_xxx

# OAuth2 (user-management)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=https://dev.example.com/login/oauth2/code/google
FRONTEND_URL=https://dev.example.com

# SMTP
SPRING_MAIL_USERNAME=your-email@example.com
SPRING_MAIL_PASSWORD=your-app-password

# Stripe
STRIPE_API_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Metamodel DB
# Optional override; if omitted they are built from postgres values
# MYAPP_DB_URL=postgresql://postgres:change-me-postgres@postgres:5432/prediction_db
# AIRFLOW_CONN_POSTGRES_MYAPP=postgresql://postgres:change-me-postgres@postgres:5432/prediction_db

# MinIO / Airflow logs
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me-minio
AIRFLOW_LOGS_BUCKET=airflow-logs
# Optional override
# AIRFLOW_CONN_AWS_DEFAULT=aws://minioadmin:change-me-minio@/?endpoint_url=http%3A%2F%2Fminio%3A9000&region_name=us-east-1
AIRFLOW_ADMIN_PASSWORD=change-me-airflow-admin

# pgAdmin
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=change-me-pgadmin

# Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me-grafana

# Consul UI (Traefik basic auth)
CONSUL_UI_USERNAME=admin
CONSUL_UI_PASSWORD=change-me-consul-ui

# Optional execution engine exchange credentials
# BINANCE_API_KEY=
# BINANCE_SECRET_KEY=

# Optional worldmonitor integration
# WORLDMONITOR_BASE_URL=
# WORLDMONITOR_TOKEN=
# WORLDMONITOR_ENDPOINT_SIGNALS=/signals
# WORLDMONITOR_TIMEOUT_SECONDS=10
