# deploy/k8s/infra/postgres/secret.yaml.example
#
# Copy to secret.yaml and fill in base64 encoded values
# Encode with: echo -n "your-value" | base64
#
# NEVER commit secret.yaml to git

apiVersion: v1
kind: Secret
metadata:
  name: postgres-credentials
  namespace: myapp
  labels:
    app.kubernetes.io/name: postgres
    app.kubernetes.io/component: database
type: Opaque
data:
  # echo -n "postgres" | base64
  POSTGRES_USER: cG9zdGdyZXM=
  # echo -n "your-strong-password" | base64
  POSTGRES_PASSWORD: eW91ci1zdHJvbmctcGFzc3dvcmQ=