# Exemple pour créer le secret GHCR — NE PAS COMMITER avec le token réel
# Commande à exécuter manuellement :
#
# kubectl create secret docker-registry ghcr-secret \
#   --namespace=myapp \
#   --docker-server=ghcr.io \
#   --docker-username=TON_GITHUB_USERNAME \
#   --docker-password=TON_GITHUB_PAT
#
# Remplace TON_GITHUB_PAT par un Personal Access Token avec scope read:packages
# GitHub → Settings → Developer settings → Personal access tokens → Generate
