# deploy/k8s/infra/consul/secret.yaml.example
#
# Copy to secret.yaml and fill in base64 encoded values
# Encode with: echo -n "your-value" | base64
#
# NEVER commit secret.yaml to git

apiVersion: v1
kind: Secret
metadata:
  name: consul-credentials
  namespace: myapp
  labels:
    app.kubernetes.io/name: consul
    app.kubernetes.io/component: service-discovery
type: Opaque
data:
  # UI basic auth credentials
  # echo -n "admin" | base64
  CONSUL_UI_USERNAME: YWRtaW4=
  # echo -n "your-strong-password" | base64
  CONSUL_UI_PASSWORD: eW91ci1zdHJvbmctcGFzc3dvcmQ=