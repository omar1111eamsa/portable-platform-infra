# deploy/k8s/infra/redis/secret.yaml.example
#
# Copy to secret.yaml and fill in base64 encoded values
# Encode with: echo -n "your-value" | base64
#
# NEVER commit secret.yaml to git

apiVersion: v1
kind: Secret
metadata:
  name: redis-credentials
  namespace: myapp
  labels:
    app.kubernetes.io/name: redis
    app.kubernetes.io/component: cache
type: Opaque
data:
  # echo -n "your-strong-redis-password" | base64
  REDIS_PASSWORD: eW91ci1zdHJvbmctcmVkaXMtcGFzc3dvcmQ=