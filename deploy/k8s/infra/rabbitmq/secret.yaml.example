# deploy/k8s/infra/rabbitmq/secret.yaml.example
#
# Copy to secret.yaml and fill in base64 encoded values
# Encode with: echo -n "your-value" | base64
#
# NEVER commit secret.yaml to git

apiVersion: v1
kind: Secret
metadata:
  name: rabbitmq-credentials
  namespace: myapp
  labels:
    app.kubernetes.io/name: rabbitmq
    app.kubernetes.io/component: message-broker
type: Opaque
data:
  # echo -n "myapp" | base64
  RABBITMQ_DEFAULT_USER: Y2FwcXVhbnQ=
  # echo -n "your-strong-password" | base64
  RABBITMQ_DEFAULT_PASS: eW91ci1zdHJvbmctcGFzc3dvcmQ=