# deploy/k8s/infra/monitoring/grafana-secret.yaml.example
#
# Copy to grafana-secret.yaml and fill in base64 encoded values
# Encode with: echo -n "your-value" | base64
#
# NEVER commit grafana-secret.yaml to git

apiVersion: v1
kind: Secret
metadata:
  name: grafana-credentials
  namespace: myapp
  labels:
    app.kubernetes.io/name: grafana
    app.kubernetes.io/component: monitoring
type: Opaque
data:
  # echo -n "admin" | base64
  GF_SECURITY_ADMIN_USER: YWRtaW4=
  # echo -n "your-strong-password" | base64
  GF_SECURITY_ADMIN_PASSWORD: eW91ci1zdHJvbmctcGFzc3dvcmQ=