# deploy/k8s/infra/minio/secret.yaml.example
#
# Copy to secret.yaml and fill in base64 encoded values
# Encode with: echo -n "your-value" | base64
#
# NEVER commit secret.yaml to git

apiVersion: v1
kind: Secret
metadata:
  name: minio-credentials
  namespace: myapp
  labels:
    app.kubernetes.io/name: minio
    app.kubernetes.io/component: object-storage
type: Opaque
data:
  # Minimum 3 characters
  # echo -n "myapp" | base64
  MINIO_ROOT_USER: Y2FwcXVhbnQ=
  # Minimum 8 characters
  # echo -n "your-strong-password" | base64
  MINIO_ROOT_PASSWORD: eW91ci1zdHJvbmctcGFzc3dvcmQ=