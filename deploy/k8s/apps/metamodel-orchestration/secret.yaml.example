# Copy to secret.yaml and fill in base64 encoded values
# NEVER commit secret.yaml to git
apiVersion: v1
kind: Secret
metadata:
  name: metamodel-db-credentials
  namespace: myapp
type: Opaque
data:
  # postgresql+psycopg2://postgres:password@postgres:5432/airflow_db
  AIRFLOW__DATABASE__SQL_ALCHEMY_CONN: ""
  # redis://:password@redis:6379/0
  AIRFLOW__CELERY__BROKER_URL: ""
  # db+postgresql://postgres:password@postgres:5432/airflow_db
  AIRFLOW__CELERY__RESULT_BACKEND: ""
  # generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
  AIRFLOW__CORE__FERNET_KEY: ""
---
apiVersion: v1
kind: Secret
metadata:
  name: metamodel-airflow-simple-auth
  namespace: myapp
type: Opaque
data:
  # echo -n "your-secret-key" | base64
  AIRFLOW__WEBSERVER__SECRET_KEY: ""
