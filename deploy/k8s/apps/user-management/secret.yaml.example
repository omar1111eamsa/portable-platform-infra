# Copy to secret.yaml and fill in base64 encoded values
# NEVER commit secret.yaml to git
apiVersion: v1
kind: Secret
metadata:
  name: google-oauth-credentials
  namespace: myapp
type: Opaque
data:
  # echo -n "your-google-client-id" | base64
  GOOGLE_CLIENT_ID: eW91ci1nb29nbGUtY2xpZW50LWlk
  # echo -n "your-google-client-secret" | base64
  GOOGLE_CLIENT_SECRET: eW91ci1nb29nbGUtY2xpZW50LXNlY3JldA==
